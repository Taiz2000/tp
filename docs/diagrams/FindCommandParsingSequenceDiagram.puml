@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":FindCommandParser" as FindCommandParser LOGIC_COLOR
participant "<<class>>\nFindMatchType" as FindMatchTypeClass LOGIC_COLOR
participant "<<class>>\nFindMatchTypeFactory" as FindMatchTypeFactory LOGIC_COLOR
participant ":ParsedFindArgs" as ParsedFindArgs LOGIC_COLOR
participant ":PersonContainsFieldsPredicate" as PersonContainsFieldsPredicate LOGIC_COLOR
participant "f:FindCommand" as FindCommand LOGIC_COLOR
end box

[-> LogicManager : execute("find ...")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("find ...")
activate AddressBookParser

create FindCommandParser
AddressBookParser -> FindCommandParser : parse(arguments)
activate FindCommandParser

FindCommandParser -> FindCommandParser : parseFindArgs(...)
activate FindCommandParser
alt m/ prefix provided
    FindCommandParser -> FindMatchTypeClass : fromToken()
    activate FindMatchTypeClass
    FindMatchTypeClass --> FindCommandParser : matchType
    deactivate FindMatchTypeClass
    create ParsedFindArgs
    FindCommandParser -> ParsedFindArgs : ParsedFindArgs(...)
    activate ParsedFindArgs
    ParsedFindArgs --> FindCommandParser :
    deactivate ParsedFindArgs
else m/ prefix not provided
    create ParsedFindArgs
    FindCommandParser -> ParsedFindArgs : ParsedFindArgs(...)
    activate ParsedFindArgs
    ParsedFindArgs --> FindCommandParser :
    deactivate ParsedFindArgs
end
deactivate FindCommandParser

FindCommandParser -> FindMatchTypeFactory : createPredicate(...)
activate FindMatchTypeFactory
create PersonContainsFieldsPredicate
FindMatchTypeFactory -> PersonContainsFieldsPredicate : create concrete subclass
activate PersonContainsFieldsPredicate
PersonContainsFieldsPredicate --> FindMatchTypeFactory : predicate
deactivate PersonContainsFieldsPredicate
FindMatchTypeFactory --> FindCommandParser : predicate
deactivate FindMatchTypeFactory

create FindCommand
FindCommandParser -> FindCommand : FindCommand(predicate)
activate FindCommand
FindCommand --> FindCommandParser : f
deactivate FindCommand

FindCommandParser --> AddressBookParser : f
deactivate FindCommandParser
FindCommandParser -[hidden]-> AddressBookParser
destroy FindCommandParser

AddressBookParser --> LogicManager : f
deactivate AddressBookParser

[<--LogicManager
deactivate LogicManager
@enduml
